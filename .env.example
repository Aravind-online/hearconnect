# ─────────────────────────────────────────────────────────────────────────────
# HearConnect – root .env
# Used by docker-compose.yml and docker-compose.prod.yml
# Copy to .env and fill in real values before running.
# ─────────────────────────────────────────────────────────────────────────────

# ── Docker Hub ────────────────────────────────────────────────────────────────
# Your Docker Hub username (required for docker-compose.prod.yml and push script)
DOCKERHUB_USER=yourdockerhubusername

# Image tag to pull/push (default: latest)
IMAGE_TAG=latest

# ── JWT Secret ────────────────────────────────────────────────────────────────
# IMPORTANT: Replace with a long random string before deploying to production!
JWT_SECRET=change-me-in-production-use-a-long-random-string

# ── Frontend API URLs (baked into the Vite build at docker-compose build time)
# Change these to your server's IP / domain when deploying to a remote host.
VITE_API_URL=http://localhost:8000
VITE_WS_URL=ws://localhost:8000/ws/sign
VITE_HEALTH_URL=http://localhost:8000/health
VITE_FPS=12
