# ─────────────────────────────────────────────────────────────────────────────
# HearConnect – Backend Dockerfile
# Python 3.11-slim + system libs required by OpenCV, MediaPipe & pyttsx3
# ─────────────────────────────────────────────────────────────────────────────

FROM python:3.11-slim

# ── System dependencies ───────────────────────────────────────────────────────
# libgl1-mesa-glx   – OpenCV
# libglib2.0-0      – OpenCV / GLib-based libs
# libsm6, libxrender1, libxext6 – OpenCV GUI (headless safe)
# espeak-ng         – pyttsx3 TTS back-end on Linux
# libespeak-ng-dev  – pyttsx3 compile-time header
# ffmpeg            – audio support (optional, safe to have)
RUN apt-get update && apt-get install -y --no-install-recommends \
        libgl1 \
        libglib2.0-0 \
        libsm6 \
        libxrender1 \
        libxext6 \
        libgles2 \
        espeak-ng \
        libespeak-ng-dev \
        ffmpeg \
    && rm -rf /var/lib/apt/lists/*

# ── Working directory ─────────────────────────────────────────────────────────
WORKDIR /app

# ── Python dependencies (cached layer) ───────────────────────────────────────
# Copy only requirements first so Docker layer-cache is invalidated only when
# dependencies actually change, not on every code edit.
COPY requirements.txt .

# Upgrade pip then install all deps; use --no-cache-dir to keep image slim.
# opencv-python-headless is swapped in to avoid pulling in X11 libs on top of
# what we already installed above (headless variant is smaller).
RUN pip install --upgrade pip --no-cache-dir \
 && pip install --no-cache-dir \
        opencv-python-headless \
 && grep -v "^opencv-python>=" requirements.txt | pip install --no-cache-dir -r /dev/stdin

# ── Application code ──────────────────────────────────────────────────────────
COPY . .

# ── Model volume mount-point ──────────────────────────────────────────────────
# sign6_model.pkl and sign6_data.pkl are generated by train.py.
# Mount a host volume here to persist them between runs.
VOLUME ["/app"]

# ── Runtime port ─────────────────────────────────────────────────────────────
EXPOSE 8000

# ── Default command ───────────────────────────────────────────────────────────
# Uvicorn with 1 worker (scale via Kubernetes / multiple containers instead).
CMD ["python", "-m", "uvicorn", "app.main:app", \
     "--host", "0.0.0.0", "--port", "8000", "--workers", "1"]
