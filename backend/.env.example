# Copy this file to .env and edit values for your environment.
# All variables are optional — defaults shown below are safe for local development.

# ── Paths (relative to backend/) ──────────────────────────────────────
MODEL_PATH=sign6_model.pkl
DATA_PATH=sign6_data.pkl

# ── Signs (must match training data labels) ───────────────────────────
SIGNS=HI,HELLO,I LOVE YOU,YES,NO,PLEASE

# ── Inference tuning ──────────────────────────────────────────────────
CONFIDENCE_THRESHOLD=0.75
SMOOTH_FRAMES=20
SAMPLES_PER_SIGN=300

# ── TTS ───────────────────────────────────────────────────────────────
SPEAK_COOLDOWN=3.0

# ── WebSocket ─────────────────────────────────────────────────────────
# Max bytes per incoming frame (512 KB default)
MAX_FRAME_BYTES=524288

# ── Server ────────────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000
LOG_LEVEL=info

# Comma-separated list of allowed origins.
# Change to your deployed frontend URL in production.
# Example: CORS_ORIGINS=https://hearconnet.example.com
CORS_ORIGINS=http://localhost:3000

# ── MongoDB ─────────────────────────────────────────────────────────
# Local MongoDB (default). For Atlas: mongodb+srv://user:pass@cluster.mongodb.net/
MONGODB_URL=mongodb://localhost:27017
MONGODB_DB_NAME=hearconnect

# ── JWT (Authentication) ──────────────────────────────────────────────────
# IMPORTANT: Replace with a long random secret before deploying!
JWT_SECRET=change-me-in-production-use-a-long-random-string
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440
CORS_ORIGINS=http://localhost:3000
